{
  "name": "n8n-nodes-tether",
  "version": "1.0.0",
  "description": "n8n community node for Tether USDT operations across 15+ blockchain networks including Ethereum, Tron, Solana, Polygon, and more",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "tether",
    "usdt",
    "stablecoin",
    "blockchain",
    "cryptocurrency",
    "ethereum",
    "tron",
    "solana",
    "polygon",
    "arbitrum",
    "optimism",
    "defi",
    "erc20",
    "trc20",
    "multi-chain"
  ],
  "license": "BUSL-1.1",
  "homepage": "https://velobpa.com",
  "author": {
    "name": "Velocity BPA",
    "email": "info@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-tether.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials --ext .ts --fix",
    "lintcheck": "eslint nodes credentials --ext .ts",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/TetherBlockchain.credentials.js",
      "dist/credentials/TetherApi.credentials.js",
      "dist/credentials/ExchangeApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Tether/Tether.node.js",
      "dist/nodes/Tether/TetherTrigger.node.js"
    ]
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "^1.23.0",
    "prettier": "^3.2.4",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@solana/spl-token": "^0.4.0",
    "@solana/web3.js": "^1.89.0",
    "@ton/ton": "^13.9.0",
    "algosdk": "^2.7.0",
    "axios": "^1.6.5",
    "ethers": "^6.10.0",
    "tronweb": "^5.3.2"
  },
  "peerDependencies": {
    "n8n-workflow": "^1.23.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
